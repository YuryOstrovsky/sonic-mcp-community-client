# SONiC MCP Community Client — backend configuration
# Copy to .env and edit values for your setup.

# ------------------------------------------------------------------
# Upstream MCP server
# ------------------------------------------------------------------

# Where the SONiC MCP Community Server is listening.
MCP_BASE_URL=http://127.0.0.1:8000

# HTTP timeout for outbound calls to the MCP server (seconds).
MCP_TIMEOUT_SECONDS=30

# ------------------------------------------------------------------
# Optional: LLM fallback for /api/nl unmatched queries
# Phase A has regex-only NL routing. LLM support arrives in Phase D.
# ------------------------------------------------------------------

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_ENABLED=0
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:3b-instruct

# ------------------------------------------------------------------
# Local tunables
# ------------------------------------------------------------------

# Backend listen port (used by uvicorn launcher when running via python -m)
CLIENT_BACKEND_PORT=5174
